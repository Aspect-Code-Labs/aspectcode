{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Aspect Code: Build Extension",
      "type": "shell",
      "command": "npm run compile",
      "options": { "cwd": "${workspaceFolder}/extension" },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Aspect Code: Start Server (optional)",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath} -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
      "options": { "cwd": "${workspaceFolder}/server" },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Aspect Code: Test CLI (sandbox)",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File ./scripts/test-cli-sandbox.ps1 -SkipBuild",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Aspect Code: Test CLI (multi-repo)",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File ./scripts/test-cli-repos.ps1 -SkipBuild",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
